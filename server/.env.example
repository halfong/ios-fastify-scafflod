# Database
DATABASE_URL=mysql://user:password@localhost:3306/mydb

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=change-me-to-a-random-secret

# Server
FASTIFY_PORT=3000
FASTIFY_HOST=127.0.0.1
FASTIFY_BODY_LIMIT=2097152
FASTIFY_DEBUG=false

# API metadata (shown in Swagger UI)
API_TITLE=My API
API_DESCRIPTION=REST API
API_VERSION=1.0.0

# Apple Sign In (optional — only needed if using /auth/apple endpoints)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
