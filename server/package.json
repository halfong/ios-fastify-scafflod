{
  "name": "server",
  "version": "0.1.0",
  "description": "Fastify API server",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx src/commands/auth/adminUser.ts"
  },
  "dependencies": {
    "@fastify/autoload": "^6.1.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.5.1",
    "@google-cloud/text-to-speech": "^5.7.0",
    "@google/genai": "^1.3.0",
    "@prisma/adapter-mariadb": "^6.8.2",
    "@prisma/client": "^6.8.2",
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "cos-nodejs-sdk-v5": "^2.14.8",
    "dotenv": "^16.5.0",
    "fastify": "^5.8.5",
    "fastify-cron": "^1.3.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.103.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "eslint": "^8.57.0",
    "prisma": "^6.8.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@elevenlabs/elevenlabs-js": "^2.0.0",
    "tencentcloud-sdk-nodejs-asr": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
